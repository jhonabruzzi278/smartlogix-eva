# SmartLogix Environment Configuration
# Copy this file to .env and fill in your values

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_HOST=postgres-db
POSTGRES_PORT=5432
DB_POOL_MAX=5

# Inter-service URLs
INVENTORY_SERVICE_URL=http://inventory-service:8082
SHIPPING_SERVICE_URL=http://shipping-service:8084
NOTIFICATION_SERVICE_URL=http://notification-service:8085

# Email (SMTP) — optional; leave blank for demo mode (emails logged to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@smartlogix.cl

# Application URL (used in email links)
APP_URL=http://localhost:3000

# JWT Authentication
JWT_SECRET=change-this-to-a-random-secret-key
JWT_EXPIRES_IN=8h

# Service config
SERVICE_NAME=smartlogix
LOG_LEVEL=info
ALLOWED_ORIGINS=*
RATE_LIMIT_MAX=200
