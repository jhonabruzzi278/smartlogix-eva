# SmartLogix Environment Configuration
# Copy this file to .env and fill in your values

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_HOST=postgres-db
POSTGRES_PORT=5432
DB_POOL_MAX=5

# AWS (LocalStack / ElasticMQ for dev)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_SQS_ENDPOINT=http://sqs-mock:9324

# Queue names
ORDERS_QUEUE=orders-queue
SHIPPING_QUEUE=shipping-queue

# Inter-service URLs
INVENTORY_SERVICE_URL=http://inventory-service:8082
SHIPPING_SERVICE_URL=http://shipping-service:8084
NOTIFICATION_SERVICE_URL=http://notification-service:8085

# Service config
SERVICE_NAME=smartlogix
LOG_LEVEL=info
ALLOWED_ORIGINS=*
RATE_LIMIT_MAX=200
